    DIM_SENSOR ||--o{ FACT_AIR_QUALITY_MEASUREMENT : sensor
    DIM_PARAMETER ||--o{ FACT_AIR_QUALITY_MEASUREMENT : pollutant
    DIM_RISK_CLASS ||--o{ FACT_AIR_QUALITY_MEASUREMENT : risk

