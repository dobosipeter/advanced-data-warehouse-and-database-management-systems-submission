# Database
POSTGRES_DB=air_quality
POSTGRES_USER=air_quality
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://air_quality:change-me@db:5432/air_quality

# OpenAQ ingestion
OPENAQ_API_KEY=
OPENAQ_BASE_URL=https://api.openaq.org/v3
OPENAQ_ISO=HU
OPENAQ_BBOX=18.9250,47.3494,19.3340,47.6130
OPENAQ_CITIES=Budapest
OPENAQ_PARAMETERS=pm25,pm10,no2,o3
INGESTION_HISTORY_DAYS=180
OPENAQ_PAGE_LIMIT=1000
OPENAQ_MAX_PAGES=20
OPENAQ_MAX_LOCATIONS=10
OPENAQ_MAX_SENSORS=
OPENAQ_REQUEST_TIMEOUT_SECONDS=30
OPENAQ_RETRY_COUNT=3
OPENAQ_RETRY_BACKOFF_SECONDS=1.5

# Services
API_HOST=0.0.0.0
API_PORT=8001
FRONTEND_PORT=8501
PROXY_PORT=8080
PROXY_TLS_PORT=8443
POSTGRES_PORT=5432
API_BIND_IP=127.0.0.1
FRONTEND_BIND_IP=127.0.0.1
POSTGRES_BIND_IP=127.0.0.1

# Deployment
APP_DOMAIN=mw79on-demo.online
API_DOMAIN=api.mw79on-demo.online
