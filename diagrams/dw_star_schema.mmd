    DIM_TIME ||--o{ FACT_POLLUTION_ALERT : alert_time
    DIM_LOCATION ||--o{ FACT_POLLUTION_ALERT : station
    DIM_PARAMETER ||--o{ FACT_POLLUTION_ALERT : pollutant
    DIM_RISK_CLASS ||--o{ FACT_POLLUTION_ALERT : risk

